# =============================================================
# .env.example — Template des variables d'environnement
# Copier ce fichier en .env et remplir les valeurs réelles
# Le fichier .env ne doit JAMAIS être commité sur GitHub
# =============================================================

# --- Sécurité (générer une clé aléatoire de 64 caractères) ---
SECRET_KEY=changez-moi-avec-une-cle-aleatoire-de-64-caracteres

# --- Compte admin (changer OBLIGATOIREMENT en production) -----
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changez-moi-en-production

# --- URLs admin secrètes (personnalisables) -------------------
ADMIN_URL_SECRET=ik-gestion-2025-prive
ADMIN_URL_DASHBOARD=ik-dashboard-prive
ADMIN_URL_LOGOUT=ik-gestion-logout

# --- Base de données ------------------------------------------
# Dev local : laisser vide (SQLite automatique)
# Production Render : postgresql://user:pass@host:5432/dbname
DATABASE_URL=

# --- Contact boutique -----------------------------------------
NUMERO_WHATSAPP=2250104144141
NUMERO_WHATSAPP2=2250585826888
EMAIL_MAGASIN=contact@ikliloune.com

# --- Réseaux sociaux ------------------------------------------
INSTAGRAM_URL=https://instagram.com/ikliloune
FACEBOOK_URL=https://facebook.com/ikliloune
TIKTOK_URL=https://tiktok.com/@ikliloune
SNAPCHAT_URL=https://snapchat.com/add/ikliloune

# --- Numéros Mobile Money ------------------------------------
ORANGE_MONEY_NUM=+225 07 48 95 69 59
MTN_MOMO_NUM=+225 05 85 82 68 88
WAVE_NUM=

# --- Seuils stock (indicateurs couleur client) ----------------
SEUIL_STOCK_BAS=3
SEUIL_STOCK_HAUT=10

# --- Serveur --------------------------------------------------
FLASK_DEBUG=True
PORT=5001
