# =============================================================
# .gitignore — Fichiers à ne JAMAIS commiter
# =============================================================

# Secrets
.env
*.env

# Base de données locale
*.db
*.sqlite
*.sqlite3
instance/

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# Environnement virtuel
.venv/
venv/
env/
ikliloune-env/
.pyenv/

# Images produits (générées à l'upload — pas dans Git)
static/images/produits/
uploads_temp/

# Tests & coverage
.pytest_cache/
htmlcov/
.coverage
coverage.xml

# IDE
.vscode/
.idea/
*.swp
*.swo

# Logs
*.log
logs/

# OS
.DS_Store
Thumbs.db
desktop.ini

# Render / Docker
*.pid
.python-version
